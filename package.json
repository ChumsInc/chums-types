{
  "name": "chums-types",
  "version": "3.5.1",
  "description": "CHUMS common types",
  "types": "./src/index.d.ts",
  "type": "module",
  "sideEffects": false,
  "scripts": {
    "build": "tsc",
    "codegen": "graphql-codegen --config graphqlrc.js",
    "version": "auto-changelog -p && git add CHANGELOG.md"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ChumsInc/chums-types.git"
  },
  "author": "Steve Montgomery",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/ChumsInc/chums-types/issues"
  },
  "homepage": "https://github.com/ChumsInc/chums-types#readme",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tsconfig/node20": "^20.1.8",
    "auto-changelog": "^2.4.0",
    "eslint": "^10.0.1",
    "globals": "^17.3.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.43.0"
  },
  "auto-changelog": {
    "template": "keepachangelog",
    "unreleased": true,
    "commitLimit": false
  },
  "exports": {
    ".": {
      "types": "./src/index.d.ts"
    },
    "./package.json": "./package.json",
    "./b2b": {
      "types": "./src/b2b/index.d.ts"
    },
    "./edi": {
      "types": "./src/edi/index.d.ts"
    },
    "./production": {
      "types": "./src/production/index.d.ts"
    },
    "./sales": {
      "types": "./src/sales/index.d.ts"
    },
    "./shopify": {
      "types": "./src/shopify/index.d.ts"
    },
    "./shopify-graphql": {
      "types": "./shopify-graphql/types/admin.types.d.ts"
    },
    "./ui": {
      "types": "./src/ui/index.d.ts"
    }
  },
  "files": [
    "src/**/*.d.ts",
    "shopify-graphql/**/*.d.ts",
    "package.json",
    "CHANGELOG.md"
  ]
}
